{
  "compilerOptions": {
    "target": "es2023",
    "moduleResolution": "bundler",
    "module": "esnext",
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "5.0"
  },
  "include": [
    "src/**/*",
    "prisma.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "prisma/migrations",
  ]
}