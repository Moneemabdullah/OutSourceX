meta {
  name: Update Milestone Status
  type: http
  seq: 3
}

patch {
  url: {{baseUrl}}/api/v1/milestones/{{milestoneId}}/status
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Origin: {{Origin}}
  Authorization: Bearer {{accessToken}}
}

body:json {
  {
    "status": "IN_PROGRESS"
  }
}