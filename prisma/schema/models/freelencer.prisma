model Freelancer {
    id  String  @id @default(cuid())
    bio String? @db.Text

    cv         String? @map("cv_url")
    hourlyRate Float?  @map("hourly_rate")

    expertiseID String?    @map("expertise_id")
    expertise   Expertise? @relation(fields: [expertiseID], references: [id], onDelete: SetNull)

    userID String @unique @map("user_id")
    user   User   @relation(fields: [userID], references: [id], onDelete: Cascade)

    contracts Contract[]
    proposals Proposal[]
    reviews   Review[]

    isDeleted Boolean   @default(false) @map("is_deleted")
    deletedAt DateTime? @map("deleted_at")
    createdAt DateTime  @default(now()) @map("created_at")
    updatedAt DateTime  @updatedAt @map("updated_at")

    @@index([userID], name: "idx_freelancer_user_id")
    @@index([expertiseID], name: "idx_freelancer_expertise_id")
    @@map("freelancers")
}
