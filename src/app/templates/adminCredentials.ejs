<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Account Created</title>
</head>
<body style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif; background-color: #f8fafc; margin: 0; padding: 20px;">
  <div style="max-width: 500px; margin: 0 auto; background: white; border-radius: 12px; padding: 32px; box-shadow: 0 4px 6px rgba(0,0,0,0.1);">
    <h1 style="color: #1e293b; margin: 0 0 16px; font-size: 24px;">Admin Account Created</h1>
    <p style="color: #475569; line-height: 1.6;">Hello <%= name %>,</p>
    <p style="color: #475569; line-height: 1.6;">An admin account has been created for you on OutsourceX platform.</p>
    
    <div style="background: #f1f5f9; border-radius: 8px; padding: 16px; margin: 24px 0;">
      <h2 style="color: #1e293b; margin: 0 0 12px; font-size: 16px;">Login Credentials</h2>
      <p style="color: #475569; margin: 4px 0;"><strong>Email:</strong> <%= email %></p>
      <p style="color: #475569; margin: 4px 0;"><strong>Temporary Password:</strong> <%= password %></p>
    </div>
    
    <p style="color: #475569; line-height: 1.6;">Please change your password after your first login.</p>
    
    <a href="https://outsourcex.com/login" style="display: inline-block; background: #2563eb; color: white; text-decoration: none; padding: 12px 24px; border-radius: 8px; margin-top: 16px;">Login Now</a>
  </div>
</body>
</html>