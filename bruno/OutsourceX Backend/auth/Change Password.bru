meta {
  name: Change Password
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/api/v1/auth/change-password
  body: json
}

headers {
  Content-Type: application/json
  Authorization: Bearer {{accessToken}}
}

body:json {
  {
    "currentPassword": "Password123",
    "newPassword": "Password456",
    "revokeOtherSessions": false
  }
}
