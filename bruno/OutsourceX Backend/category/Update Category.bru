}

patch {
  url: {{baseUrl}}/api/v1/categories/{{categoryId}}
  body: json
  auth: none
}

headers {
  Content-Type: application/json
  Origin: {{Origin}}
  Authorization: Bearer {{accessToken}}
}

body:json {
  {
    "name": "Web Development Updated",
    "description": "Updated description"
  }
}